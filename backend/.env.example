BANDO_BACKEND_PORT=1122
NODE_ENV=production
BANDO_PUBLIC_URL=http://YOUR_PUBLIC_IP:1122
BANDO_AUTH_SECRET=change-this-admin-login-secret
BANDO_AUTH_TOKEN_DAYS=7

# MySQL DB for BANDO on the VPS.
BANDO_DB_HOST=127.0.0.1
BANDO_DB_PORT=3306
BANDO_DB_USER=root
BANDO_DB_PASS=
BANDO_DB_NAME=bando

# Optional: only needed when importing item names from the game server DB.
NSO_SERVER_MYSQL_PROPERTIES=
NSO_SERVER_DB_NAME=ninja_game_server1
# 0 = mỗi lần web/BOT lấy dữ liệu theo server sẽ kiểm tra DB item của server đó.
# Tăng lên 60000 nếu muốn cache 60 giây để giảm tải DB game.
BANDO_SERVER_ITEM_SYNC_MS=300000

# Optional shared secret for the payment gateway webhook.
# If empty, the webhook can still be protected by callback signatures saved
# on each bank account in the admin web.
BANDO_BANK_WEBHOOK_TOKEN=change-this-local-secret

# Optional: backend polls the bank transaction-history API itself.
# Keep disabled until the exact API URL and token format are known.
BANDO_BANK_SYNC_ENABLED=0
BANDO_BANK_API_URL=https://api.example.com/mbbank/transactions
BANDO_BANK_API_TOKEN=your-api-token-here

# Token modes:
# - bearer: Authorization: Bearer <token>
# - header: <BANDO_BANK_TOKEN_NAME>: <token>
# - x-api-key: x-api-key: <token>
# - query: ?token=<token>, or ?<BANDO_BANK_TOKEN_NAME>=<token>
BANDO_BANK_TOKEN_MODE=bearer
BANDO_BANK_TOKEN_NAME=
BANDO_BANK_POLL_MS=10000

# Optional Telegram admin bot.
# Bot co the gui thong bao vao group. Reply tin giao dich bang ok/no de duyet/huy.
BANDO_TELEGRAM_ENABLED=0
BANDO_TELEGRAM_BOT_TOKEN=
BANDO_TELEGRAM_CHAT_IDS=
BANDO_TELEGRAM_ALLOWED_USER_IDS=
BANDO_TELEGRAM_POLL_MS=2500
BANDO_TELEGRAM_ORDER_POLL_MS=5000

# Optional VietQR image for Telegram payout notifications.
# When customers sell xu and submit bank info, Telegram receives a QR to pay them.
BANDO_VIETQR_ENABLED=1
BANDO_VIETQR_TEMPLATE=compact2
BANDO_VIETQR_FORMAT=png
